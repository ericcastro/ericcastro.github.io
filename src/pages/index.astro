---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import PostCard from "../components/PostCard.astro";
import { getSortedPosts, POSTS_PER_PAGE } from "../lib/posts";

const [aboutEntry] = await getCollection("about");
const postEntries = await getSortedPosts();
const projectEntries = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order
);

if (!aboutEntry) {
  throw new Error("Missing about content entry in src/content/about.");
}

const aboutRendered = await render(aboutEntry);
const AboutContent = aboutRendered.Content;
const initialPosts = postEntries.slice(0, POSTS_PER_PAGE);
const totalPostPages = Math.ceil(postEntries.length / POSTS_PER_PAGE);
const pageTitle = "Eric Castro - Personal Website";
const pageDescription =
  "Eric Castro's personal website: full-stack development, cybersecurity, electronics projects, music, and other weird side projects.";
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Eric Castro",
  url: "https://eric.cast.ro",
  jobTitle: "Full-stack developer and creative technologist",
  knowsAbout: [
    "Full-stack development",
    "Cybersecurity",
    "Electronics",
    "3D printing",
    "Music",
    "Interface design"
  ],
  description: pageDescription,
  homeLocation: {
    "@type": "Place",
    name: aboutEntry.data.location
  }
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  schema={personSchema}
>
  <div class="desktop">
    <div class="desktop-icons">
      <div class="desktop-icon" id="myComputerIcon" tabindex="0">
        <div class="icon icon-computer"></div>
        <div class="icon-label">My Computer</div>
      </div>
      <div class="desktop-icon" data-icon="browser" tabindex="0">
        <div class="icon icon-ie"></div>
        <div class="icon-label">Internet Exploder</div>
      </div>
      <div class="desktop-icon" data-icon="notes" tabindex="0">
        <div class="icon icon-notepad"></div>
        <div class="icon-label">Bio.txt</div>
      </div>
      <div class="desktop-icon" data-icon="projects" tabindex="0">
        <div class="icon icon-folder"></div>
        <div class="icon-label">Projects</div>
      </div>
      <div class="desktop-icon" data-icon="cmd" tabindex="0">
        <div class="icon icon-cmd"></div>
        <div class="icon-label">Command Prompt</div>
      </div>
    </div>

    <section
      class="window active"
      id="browser"
      data-window
      data-title="Microsoff Internet Exploder"
      style="left: 280px; top: 38px; width: 760px; height: 500px; z-index: 35;"
    >
        <div class="title-bar" data-drag-handle>
        <div class="title-left">
          <div class="title-icon ie"></div>
          <div class="title-text" id="browserWindowTitle">Microsoff Internet Exploder - https://eric.cast.ro</div>
        </div>
        <div class="title-buttons">
          <button class="win-btn min" data-action="minimize" aria-label="Minimize"></button>
          <button class="win-btn max" data-action="maximize" aria-label="Maximize"></button>
          <button class="win-btn close" data-action="close" aria-label="Close"></button>
        </div>
      </div>
      <div class="menu-bar"><span>File</span><span>Edit</span><span>View</span><span>Go</span><span>Favorites</span><span>Help</span></div>
      <div class="window-content">
        <div class="ie-shell">
          <div class="ie-toolbar">
            <div class="ie-toolbar-left">
              <button class="nav-btn" type="button"><span class="glyph" aria-hidden="true"><img class="toolbar-icon toolbar-icon-back" src="/images/button-back.png" alt="" width="16" height="14" /></span><span class="label">Back</span></button>
              <button class="nav-btn" type="button"><span class="glyph" aria-hidden="true"><img class="toolbar-icon toolbar-icon-forward" src="/images/button-forward.png" alt="" width="16" height="14" /></span><span class="label">Forward</span></button>
              <button class="nav-btn" type="button"><span class="glyph" aria-hidden="true"><img class="toolbar-icon toolbar-icon-stop" src="/images/button-stop.png" alt="" width="19" height="19" /></span><span class="label">Stop</span></button>
              <button class="nav-btn" type="button"><span class="glyph" aria-hidden="true"><img class="toolbar-icon toolbar-icon-refresh" src="/images/button-refresh.png" alt="" width="17" height="19" /></span><span class="label">Refresh</span></button>
              <button class="nav-btn" type="button"><span class="glyph" aria-hidden="true"><img class="toolbar-icon toolbar-icon-home" src="/images/button-home.png" alt="" width="19" height="20" /></span><span class="label">Home</span></button>
            </div>
            <div class="address-row">
              <div class="address-label">Address</div>
              <div class="address-box" id="browserAddress">https://eric.cast.ro</div>
            </div>
            <div class="ie-badge sunken" aria-hidden="true">
              <div class="ie-badge-icon"></div>
            </div>
          </div>

          <div class="win-scroll-shell win-scroll-shell-flex">
            <div class="ie-page sunken win-scroll">
            <div class="retro-banner">
              <img class="retro-banner-photo" src="/images/eric.gif" alt="Eric Castro" />
              <div class="retro-banner-copy">
                <h1>Eric's Stuff</h1>
                <p>Welcome to my personal space in the World Wide Web!</p>
              </div>
            </div>

            <div class="marquee-box">
              <div class="marquee-track" aria-label="Scrolling announcement">
                <span>
                  ★ best viewed with Microsoff Internet Exploder 3.0 ★ under construction since 1998 ★ this website uses JavaScript and cookies ★
                </span>
                <span aria-hidden="true">
                  ★ best viewed with Microsoff Internet Exploder 3.0 ★ under construction since 1998 ★ this website uses JavaScript and cookies ★
                </span>
              </div>
            </div>

            <div class="ie-layout">
              <div class="sidebar-column">
                <aside class="sidebar90s">
                  <button
                    class="dark-toggle"
                    id="darkModeToggle"
                    type="button"
                    role="checkbox"
                    aria-checked="false"
                  >
                    <span class="dark-toggle-box" aria-hidden="true"></span>
                    <span class="dark-toggle-label">Dark Mode</span>
                  </button>

                  <div class="sidebar-divider" aria-hidden="true"></div>

                  <h3>Site Menu</h3>
                  <ul>
                    <li><a href="/" data-browser-home>Homepage</a></li>
                    <li><a href="#" data-open-window="notes">About Me</a></li>
                    <li><a href="#" data-open-window="projects">Projects</a></li>
                    <li><a href="#" data-open-window="cmd">System Info</a></li>
                  </ul>

                  <h3>Cool Links</h3>
                  <ul>
                    <li><a href="https://www.linkedin.com/in/eric-castro-92b2975b/" target="_blank" rel="noreferrer">LinkedIn</a></li>
                    <li><a href="https://github.com/ericcastro/" target="_blank" rel="noreferrer">Github</a></li>
                    <li><a href="https://www.last.fm/user/eric_castro" target="_blank" rel="noreferrer">Last.fm</a></li>
                    <li><a href="https://mastodon.social/@ericcastro" target="_blank" rel="noreferrer">Mastodon</a></li>
                    <li><a href="#" id="emailLink">E-mail</a></li>
                    <li><a href="#" id="guestbookLink">Guestbook</a></li>
                  </ul>

                </aside>

                <div class="sidebar-construction">
                  <img
                    class="construction-gif"
                    alt="under construction"
                    src="/images/construction.gif"
                    width="202"
                    height="27"
                    style="display:block;max-width:100%;height:auto;image-rendering:pixelated;"
                  />
                </div>

                <div class="sidebar-badges">
                  <img
                    src="/images/banner-best-viewed-with-any-browser-1996.gif"
                    alt="Best viewed with any browser"
                  />
                  <img
                    src="/images/banner-campaign-against-frames-1996.gif"
                    alt="Campaign against frames"
                  />
                  <img
                    src="/images/banner-made-with-notepad.gif"
                    alt="Made with Notepad"
                  />
                </div>

                <div class="sidebar-powered">
                  powered by <a href="/projects/ericos-95/">Eric OS 95</a>
                </div>
              </div>

              <main class="content90s" id="top">
                <template id="browserHomeTemplate">
                  <div
                    id="postsFeed"
                    data-next-page="2"
                    data-total-pages={totalPostPages}
                  >
                    {initialPosts.map((entry) => <PostCard entry={entry} />)}
                  </div>
                  <div class="infinite-status" id="postFeedStatus" aria-live="polite">
                    {totalPostPages > 1 ? "Scroll down for older posts." : "All posts loaded."}
                  </div>
                  <div class="post-sentinel" id="postFeedSentinel" aria-hidden="true"></div>

                  <div class="guestbook">
                    <strong>Sign My Guestbook!</strong>
                    <p>Tell me your modem speed, your favorite operating system, and whether animated GIFs should make a comeback.</p>
                    <div class="counter90s" aria-label="visitor counter">
                      <span>0</span><span>0</span><span>1</span><span>3</span><span>3</span><span>7</span>
                    </div>
                  </div>
                </template>
                <div id="browserContent">
                  <div
                    id="postsFeed"
                    data-next-page="2"
                    data-total-pages={totalPostPages}
                  >
                    {initialPosts.map((entry) => <PostCard entry={entry} />)}
                  </div>
                  <div class="infinite-status" id="postFeedStatus" aria-live="polite">
                    {totalPostPages > 1 ? "Scroll down for older posts." : "All posts loaded."}
                  </div>
                  <div class="post-sentinel" id="postFeedSentinel" aria-hidden="true"></div>

                  <div class="guestbook">
                    <strong>Sign My Guestbook!</strong>
                    <p>Tell me your modem speed, your favorite operating system, and whether animated GIFs should make a comeback.</p>
                    <div class="counter90s" aria-label="visitor counter">
                      <span>0</span><span>0</span><span>1</span><span>3</span><span>3</span><span>7</span>
                    </div>
                  </div>
                </div>
              </main>
            </div>
            <div class="footer90s">
              Copyright © 2026 Eric Castro. All rights reserved.
            </div>
          </div>
          </div>
        </div>
        <div class="status-bar">
          <div>Done</div>
          <div>Internet zone</div>
        </div>
      </div>
      <div class="resize-handle n" data-resize="n"></div>
      <div class="resize-handle e" data-resize="e"></div>
      <div class="resize-handle s" data-resize="s"></div>
      <div class="resize-handle w" data-resize="w"></div>
      <div class="resize-handle nw" data-resize="nw"></div>
      <div class="resize-handle ne" data-resize="ne"></div>
      <div class="resize-handle sw" data-resize="sw"></div>
      <div class="resize-handle se" data-resize="se"></div>
    </section>

    <section
      class="window active"
      id="notes"
      data-window
      data-title="Bio.txt - Notepad"
      style="left: 28px; top: 292px; width: 396px; height: 340px; z-index: 42;"
    >
      <div class="title-bar" data-drag-handle>
        <div class="title-left">
          <div class="title-icon note"></div>
          <div class="title-text">Bio.txt - Notepad</div>
        </div>
        <div class="title-buttons">
          <button class="win-btn min" data-action="minimize" aria-label="Minimize"></button>
          <button class="win-btn max" data-action="maximize" aria-label="Maximize"></button>
          <button class="win-btn close" data-action="close" aria-label="Close"></button>
        </div>
      </div>
      <div class="menu-bar"><span>File</span><span>Edit</span><span>Search</span><span>Help</span></div>
      <div class="window-content">
        <div class="win-scroll-shell win-scroll-shell-about">
          <div class="about-body sunken win-scroll">
            <div
              class="markdown-body editable-note editable-note-full"
              contenteditable="true"
              spellcheck="false"
              aria-label="Editable About Me text"
            >
              <p>{aboutEntry.data.name}</p>
              <p>{aboutEntry.data.tagline}</p>
              <p>{aboutEntry.data.intro}</p>
              <p>--------------------</p>
              <p>Location: {aboutEntry.data.location}</p>
              <p>Occupation: {aboutEntry.data.occupation}</p>
              <p>Likes: {aboutEntry.data.likes}</p>
              <p>Status: {aboutEntry.data.status}</p>
              <p>--------------------</p>
              <p>{aboutEntry.data.heading}</p>
              <AboutContent />
            </div>
          </div>
        </div>
        <div class="status-bar">
          <div>Ln 1, Col 1</div>
          <div>100%</div>
        </div>
      </div>
      <div class="resize-handle n" data-resize="n"></div>
      <div class="resize-handle e" data-resize="e"></div>
      <div class="resize-handle s" data-resize="s"></div>
      <div class="resize-handle w" data-resize="w"></div>
      <div class="resize-handle nw" data-resize="nw"></div>
      <div class="resize-handle ne" data-resize="ne"></div>
      <div class="resize-handle sw" data-resize="sw"></div>
      <div class="resize-handle se" data-resize="se"></div>
    </section>

    <section
      class="window hidden"
      id="projects"
      data-window
      data-title="Projects - Paint"
      style="left: 440px; top: 96px; width: 540px; height: 474px; z-index: 20;"
    >
      <div class="title-bar" data-drag-handle>
        <div class="title-left">
          <div class="title-icon paint"></div>
          <div class="title-text">Projects - Paint</div>
        </div>
        <div class="title-buttons">
          <button class="win-btn min" data-action="minimize" aria-label="Minimize"></button>
          <button class="win-btn max" data-action="maximize" aria-label="Maximize"></button>
          <button class="win-btn close" data-action="close" aria-label="Close"></button>
        </div>
      </div>
      <div class="menu-bar"><span>File</span><span>Edit</span><span>View</span><span>Image</span><span>Help</span></div>
      <div class="window-content">
        <div class="projects-layout">
          <div class="toolbox sunken">
            <div class="tool"></div><div class="tool"></div><div class="tool"></div>
            <div class="tool"></div><div class="tool"></div><div class="tool"></div>
          </div>
          <div class="paint-side">
            <div class="canvas-wrap sunken">
              <div class="canvas" id="projects-board">
                {
                  projectEntries.map((project) => (
                    <div
                      class:list={["pixel-card", project.data.color !== "yellow" && project.data.color]}
                      style={`left: ${project.data.x}px; top: ${project.data.y}px;${project.data.width ? ` width: ${project.data.width}px;` : ""}`}
                    >
                      <a href={`/projects/${project.slug}/`} class="pixel-card-link">
                        <strong>{project.data.title}</strong>
                        {project.data.summary}
                        <span class="pixel-card-period">{project.data.period}</span>
                      </a>
                    </div>
                  ))
                }
              </div>
            </div>
            <div class="palette sunken">
              <div class="swatch" style="background:black"></div><div class="swatch" style="background:gray"></div><div class="swatch" style="background:maroon"></div><div class="swatch" style="background:red"></div><div class="swatch" style="background:orange"></div><div class="swatch" style="background:yellow"></div><div class="swatch" style="background:lime"></div><div class="swatch" style="background:cyan"></div><div class="swatch" style="background:blue"></div><div class="swatch" style="background:fuchsia"></div><div class="swatch" style="background:white"></div>
            </div>
          </div>
        </div>
        <div class="status-bar"><div>For Help, click Help Topics on the Help Menu.</div></div>
      </div>
      <div class="resize-handle n" data-resize="n"></div>
      <div class="resize-handle e" data-resize="e"></div>
      <div class="resize-handle s" data-resize="s"></div>
      <div class="resize-handle w" data-resize="w"></div>
      <div class="resize-handle nw" data-resize="nw"></div>
      <div class="resize-handle ne" data-resize="ne"></div>
      <div class="resize-handle sw" data-resize="sw"></div>
      <div class="resize-handle se" data-resize="se"></div>
    </section>

    <section
      class="window hidden"
      id="cmd"
      data-window
      data-title="C:\WINDOWS\SYSTEM32\CMD.EXE"
      style="left: 240px; top: 180px; width: 420px; height: 320px; z-index: 15;"
    >
      <div class="title-bar" data-drag-handle>
        <div class="title-left">
          <div class="title-icon cmd"></div>
          <div class="title-text">C:\WINDOWS\SYSTEM32\CMD.EXE</div>
        </div>
        <div class="title-buttons">
          <button class="win-btn min" data-action="minimize" aria-label="Minimize"></button>
          <button class="win-btn max" data-action="maximize" aria-label="Maximize"></button>
          <button class="win-btn close" data-action="close" aria-label="Close"></button>
        </div>
      </div>
      <div class="window-content cmd-window-content">
        <div class="win-scroll-shell win-scroll-shell-fill">
          <div class="cmd-shell sunken win-scroll">Microsoff(R) Windows 95
(C)Copyright Microsoff Corp 1981-1995.

<span class="prompt">C:\&gt;</span> net user webmaster
Name                Eric Castro
Role                Builder of things
Location            Paris, France
Status              ONLINE

<span class="prompt">C:\&gt;</span> dir widgets
BIO      TXT
PROJECTS BMP
SITE     HTM

<span class="prompt">C:\&gt;</span> <span class="cmd-cursor">_</span></div>
        </div>
      </div>
      <div class="resize-handle n" data-resize="n"></div>
      <div class="resize-handle e" data-resize="e"></div>
      <div class="resize-handle s" data-resize="s"></div>
      <div class="resize-handle w" data-resize="w"></div>
      <div class="resize-handle nw" data-resize="nw"></div>
      <div class="resize-handle ne" data-resize="ne"></div>
      <div class="resize-handle sw" data-resize="sw"></div>
      <div class="resize-handle se" data-resize="se"></div>
    </section>

    <section
      class="window cookie-window is-hidden"
      id="cookieWidget"
      role="dialog"
      aria-live="polite"
      aria-label="Cookie notice"
      style="width: 320px; min-height: 0; z-index: 48;"
    >
      <div class="title-bar">
        <div class="title-left">
          <div class="title-icon note"></div>
          <div class="title-text">Cookie Notice</div>
        </div>
      </div>
      <div class="window-content cookie-body">
        <div class="alert-row">
          <div class="alert-symbol info" aria-hidden="true"></div>
          <p>This website uses cookies for extremely serious settings management and general European compliance theater.</p>
        </div>
        <div class="cookie-actions">
          <button class="ie-link-btn" id="cookieAccept" type="button">Accept All Cookies</button>
          <button class="ie-link-btn" id="cookieDecline" type="button">Decline</button>
        </div>
      </div>
    </section>

    <section
      class="window cookie-window is-hidden"
      id="myComputerWidget"
      role="dialog"
      aria-live="polite"
      aria-label="My Computer"
      style="width: 360px; min-height: 0; z-index: 47;"
    >
      <div class="title-bar">
        <div class="title-left">
          <div class="title-icon computer"></div>
          <div class="title-text">EricOS 95</div>
        </div>
      </div>
      <div class="window-content cookie-body">
        <div class="alert-row">
          <div class="alert-symbol warning" aria-hidden="true"></div>
          <p>I find it a bit weird that you want to access my computer. You can request access, but I don't guarantee I will give it to you anytime soon.</p>
        </div>
        <div class="cookie-actions">
          <button class="ie-link-btn" id="computerRequest" type="button">Request access</button>
          <button class="ie-link-btn" id="computerCancel" type="button">Cancel</button>
        </div>
      </div>
    </section>

    <section
      class="window cookie-window is-hidden"
      id="requestResultWidget"
      role="dialog"
      aria-live="polite"
      aria-label="EricOS 95"
      style="width: 250px; min-height: 0; z-index: 49;"
    >
      <div class="title-bar">
        <div class="title-left">
          <div class="title-icon computer"></div>
          <div class="title-text">EricOS 95</div>
        </div>
      </div>
      <div class="window-content cookie-body">
        <div class="alert-row">
          <div class="alert-symbol info" aria-hidden="true"></div>
          <p>Task failed successfully.</p>
        </div>
        <div class="cookie-actions">
          <button class="ie-link-btn" id="requestResultOk" type="button">OK</button>
        </div>
      </div>
    </section>

    <section
      class="window cookie-window is-hidden"
      id="guestbookWidget"
      role="dialog"
      aria-live="polite"
      aria-label="Guestbook"
      style="width: 240px; min-height: 0; z-index: 49;"
    >
      <div class="title-bar">
        <div class="title-left">
          <div class="title-icon note"></div>
          <div class="title-text">EricOS 95</div>
        </div>
      </div>
      <div class="window-content cookie-body">
        <div class="alert-row">
          <div class="alert-symbol info" aria-hidden="true"></div>
          <p>Under construction. Sorry.</p>
        </div>
        <div class="cookie-actions">
          <button class="ie-link-btn" id="guestbookOk" type="button">OK</button>
        </div>
      </div>
    </section>

    <section
      class="window cookie-window is-hidden"
      id="emailWidget"
      role="dialog"
      aria-live="polite"
      aria-label="EricOS 95"
      style="width: 290px; min-height: 0; z-index: 49;"
    >
      <div class="title-bar">
        <div class="title-left">
          <div class="title-icon note"></div>
          <div class="title-text">EricOS 95</div>
        </div>
      </div>
      <div class="window-content cookie-body">
        <div class="alert-row">
          <div class="alert-symbol info" aria-hidden="true"></div>
          <p>You can contact me at eric(at)cast.ro</p>
        </div>
        <div class="cookie-actions">
          <button class="ie-link-btn" id="emailOk" type="button">OK</button>
        </div>
      </div>
    </section>

    <section
      class="window cookie-window is-hidden"
      id="shutdownWidget"
      role="dialog"
      aria-live="polite"
      aria-label="EricOS 95"
      style="width: 260px; min-height: 0; z-index: 49;"
    >
      <div class="title-bar">
        <div class="title-left">
          <div class="title-icon note"></div>
          <div class="title-text">EricOS 95</div>
        </div>
      </div>
      <div class="window-content cookie-body">
        <div class="alert-row">
          <div class="alert-symbol info" aria-hidden="true"></div>
          <p>It is now safe to turn off your browser.</p>
        </div>
        <div class="cookie-actions">
          <button class="ie-link-btn" id="shutdownOk" type="button">OK</button>
        </div>
      </div>
    </section>
  </div>

  <div class="taskbar">
    <button class="start-btn" id="startButton" type="button" aria-expanded="false">
      <span class="start-logo"></span>
      <span>Start</span>
    </button>
    <div class="start-menu hidden" id="startMenu">
      <div class="start-menu-side">
        <span class="start-menu-brand">EricOS 95</span>
      </div>
      <div class="start-menu-main">
        <div class="start-menu-item-wrap has-submenu">
          <button
            class="start-menu-item start-menu-submenu-toggle"
            type="button"
            data-start-submenu-toggle="cool-links"
            aria-expanded="false"
          >
            <span class="title-icon ie start-menu-icon"></span>
            <span>Cool Links</span>
            <span class="submenu-arrow" aria-hidden="true"></span>
          </button>
          <div class="start-submenu" data-start-submenu="cool-links">
            <a
              class="start-menu-item"
              href="https://www.linkedin.com/in/eric-castro-92b2975b/"
              target="_blank"
              rel="noreferrer"
            >
              <span class="title-icon ie start-menu-icon"></span>
              <span>LinkedIn</span>
            </a>
            <a
              class="start-menu-item"
              href="https://github.com/ericcastro/"
              target="_blank"
              rel="noreferrer"
            >
