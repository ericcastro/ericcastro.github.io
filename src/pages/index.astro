      id="guestbookWidget"
      role="dialog"
      aria-live="polite"
      aria-label="Guestbook"
      style="width: 240px; min-height: 0; z-index: 49;"
    >
      <div class="title-bar">
        <div class="title-left">
          <div class="title-text title-bar-text">EricOS 95</div>
        </div>
      </div>
      <div class="window-content cookie-body">
        <div class="alert-row">
          <div class="alert-symbol info" aria-hidden="true"></div>
          <p>Under construction. Sorry.</p>
        </div>
        <div class="dialog-actions">
          <button class="default" id="guestbookOk" type="button">OK</button>
        </div>
      </div>
    </section>

    <section
      class="window cookie-window is-hidden"
      id="emailWidget"
      role="dialog"
      aria-live="polite"
      aria-label="EricOS 95"
      style="width: 290px; min-height: 0; z-index: 49;"
    >
      <div class="title-bar">
        <div class="title-left">
          <div class="title-text title-bar-text">EricOS 95</div>
        </div>
      </div>
      <div class="window-content cookie-body">
        <div class="alert-row">
          <div class="alert-symbol info" aria-hidden="true"></div>
          <p>You can contact me at eric(at)cast.ro</p>
        </div>
        <div class="dialog-actions">
          <button class="default" id="emailOk" type="button">OK</button>
        </div>
      </div>
    </section>

    <section
      class="window cookie-window is-hidden"
      id="shutdownConfirmWidget"
      role="dialog"
      aria-live="polite"
      aria-label="EricOS 95"
      style="width: 280px; min-height: 0; z-index: 49;"
    >
      <div class="title-bar">
        <div class="title-left">
          <div class="title-text title-bar-text">EricOS 95</div>
        </div>
      </div>
      <div class="window-content cookie-body">
        <div class="alert-row">
          <div class="alert-symbol warning" aria-hidden="true"></div>
          <p>Are you sure you want to shut down?</p>
        </div>
        <div class="dialog-actions">
          <button class="default" id="shutdownYes" type="button">Yes</button>
          <button id="shutdownNo" type="button">No</button>
        </div>
      </div>
    </section>

    <section
      class="window cookie-window is-hidden"
      id="shutdownWidget"
      role="dialog"
      aria-live="polite"
      aria-label="EricOS 95"
      style="width: 260px; min-height: 0; z-index: 49;"
    >
      <div class="title-bar">
        <div class="title-left">
          <div class="title-text title-bar-text">EricOS 95</div>
        </div>
      </div>
      <div class="window-content cookie-body">
        <div class="alert-row">
          <div class="alert-symbol info" aria-hidden="true"></div>
          <p>It is now safe to turn off your browser.</p>
        </div>
        <div class="dialog-actions">
          <button class="default" id="shutdownOk" type="button">OK</button>
        </div>
      </div>
    </section>
