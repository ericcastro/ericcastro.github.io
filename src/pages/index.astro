---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import PostCard from "../components/PostCard.astro";
import { getSortedPosts, POSTS_PER_PAGE } from "../lib/posts";

const [aboutEntry] = await getCollection("about");
const [cmdEntry] = await getCollection("cmd");
const postEntries = await getSortedPosts();
const projectEntries = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order
);

if (!aboutEntry) {
  throw new Error("Missing about content entry in src/content/about.");
}

if (!cmdEntry) {
  throw new Error("Missing cmd content entry in src/content/cmd.");
}

const aboutNoteText = `${aboutEntry.data.heading}\n\n${aboutEntry.body.trim()}`;
const initialPosts = postEntries.slice(0, POSTS_PER_PAGE);
const totalPostPages = Math.ceil(postEntries.length / POSTS_PER_PAGE);
const pageTitle = "Eric Castro - Personal Website";
const pageDescription =
  "Eric Castro's personal website: full-stack development, cybersecurity, electronics projects, music, and other weird side projects.";
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Eric Castro",
  url: "https://eric.cast.ro",
  jobTitle: "Full-stack developer and creative technologist",
  knowsAbout: [
    "Full-stack development",
    "Cybersecurity",
    "Electronics",
    "3D printing",
    "Music",
    "Interface design"
  ],
  description: pageDescription,
  homeLocation: {
    "@type": "Place",
    name: cmdEntry.data.location
  }
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  schema={personSchema}
>
  <div class="desktop">
    <div class="desktop-icons">
      <div class="desktop-icon" id="myComputerIcon" tabindex="0">
        <div class="icon icon-computer"></div>
        <div class="icon-label">My Computer</div>
      </div>
      <div class="desktop-icon" data-icon="browser" tabindex="0">
        <div class="icon icon-ie"></div>
        <div class="icon-label">Internet Ersplorer</div>
      </div>
      <div class="desktop-icon" data-icon="cmd" tabindex="0">
        <div class="icon icon-cmd"></div>
        <div class="icon-label">Command Prompt</div>
      </div>
      <div class="desktop-icon" data-icon="projects" tabindex="0">
        <div class="icon icon-folder"></div>
        <div class="icon-label">PROJECTS.BMP</div>
      </div>
      <div class="desktop-icon" data-icon="notes" tabindex="0">
        <div class="icon icon-notepad"></div>
        <div class="icon-label">README.TXT</div>
      </div>
      <div class="desktop-icon" data-icon="retruco" tabindex="0">
        <div class="icon icon-retruco"></div>
        <div class="icon-label">RETRUCO.EXE</div>
      </div>
    </div>

    <section
      class="window active"
      id="browser"
      data-window
      data-title="Microsoff Internet Ersplorer"
      style="left: 280px; top: 48px; width: 760px; height: 500px; z-index: 35;"
    >
        <div class="title-bar" data-drag-handle>
        <div class="title-left">
          <div class="title-icon ie"></div>
          <div class="title-text title-bar-text" id="browserWindowTitle">https://eric.cast.ro - Microsoff Internet Ersplorer</div>
        </div>
        <div class="title-bar-controls">
          <button class="win-btn minimize" data-action="minimize" aria-label="Minimize"></button>
          <button class="win-btn maximize" data-action="maximize" aria-label="Maximize"></button>
          <button class="win-btn close" data-action="close" aria-label="Close"></button>
        </div>
      </div>
      <div class="menu-bar"><span>File</span><span>Edit</span><span>View</span><span>Go</span><span>Favorites</span><span>Help</span></div>
      <div class="window-content browser-window-content">
        <div class="ie-shell">
          <div class="ie-toolbar">
            <fieldset class="toolbar-group">
              <div class="ie-toolbar-left">
                <button class="nav-btn nav-btn-back" type="button"><span class="glyph" aria-hidden="true"><img class="toolbar-icon toolbar-icon-back" src="/images/button-back.png" alt="" width="16" height="14" /></span><span class="label">Back</span></button>
                <button class="nav-btn nav-btn-forward" type="button"><span class="glyph" aria-hidden="true"><img class="toolbar-icon toolbar-icon-forward" src="/images/button-forward.png" alt="" width="16" height="14" /></span><span class="label">Forward</span></button>
                <button class="nav-btn nav-btn-stop" type="button"><span class="glyph" aria-hidden="true"><img class="toolbar-icon toolbar-icon-stop" src="/images/button-stop.png" alt="" width="19" height="19" /></span><span class="label">Stop</span></button>
                <button class="nav-btn nav-btn-refresh" type="button"><span class="glyph" aria-hidden="true"><img class="toolbar-icon toolbar-icon-refresh" src="/images/button-refresh.png" alt="" width="17" height="19" /></span><span class="label">Refresh</span></button>
                <button class="nav-btn nav-btn-home" type="button"><span class="glyph" aria-hidden="true"><img class="toolbar-icon toolbar-icon-home" src="/images/button-home.png" alt="" width="19" height="20" /></span><span class="label">Home</span></button>
              </div>
            </fieldset>
            <div class="address-row">
              <div class="address-label">Address</div>
              <div
                class="address-box"
                id="browserAddress"
                contenteditable="true"
                spellcheck="false"
                aria-label="Address bar"
              >https://eric.cast.ro</div>
            </div>
            <div class="ie-badge sunken" aria-hidden="true">
              <div class="ie-badge-icon"></div>
            </div>
          </div>

          <div class="win-scroll-shell win-scroll-shell-flex">
            <div class="ie-page sunken win-scroll">
            <div class="retro-banner">
              <img class="retro-banner-photo" src="/images/eric.gif" alt="Eric Castro" />
              <div class="retro-banner-copy">
                <h1>Eric's Stuff</h1>
                <p>Welcome to my personal space in the World Wide Web!</p>
              </div>
            </div>

            <div class="marquee-box">
              <div class="marquee-track" aria-label="Scrolling announcement">
                <span>
                  ★ best viewed with Microsoff Internet Ersplorer 3.0 ★ under construction since 1998 ★ this website uses JavaScript and cookies ★
                </span>
                <span aria-hidden="true">
                  ★ best viewed with Microsoff Internet Ersplorer 3.0 ★ under construction since 1998 ★ this website uses JavaScript and cookies ★
                </span>
              </div>
            </div>

            <div class="ie-layout">
              <div class="sidebar-column">
                <aside class="sidebar90s">
                  <div class="field-row dark-toggle">
                    <input id="darkModeToggle" type="checkbox" />
                    <label class="dark-toggle-label" for="darkModeToggle">Dark Mode</label>
                  </div>

                  <div class="sidebar-divider" aria-hidden="true"></div>

                  <h3>Site Menu</h3>
                  <ul>
                    <li><a href="/" data-browser-home>Homepage</a></li>
                    <li><a href="javascript:void(0)" data-open-window="notes">About Me</a></li>
                    <li><a href="javascript:void(0)" data-open-window="projects">Projects</a></li>
                    <li><a href="javascript:void(0)" data-open-window="cmd">System Info</a></li>
                  </ul>

                  <h3>Cool Links</h3>
                  <ul>
                    <li><a href="https://www.linkedin.com/in/eric-castro-92b2975b/" target="_blank" rel="noreferrer">LinkedIn</a></li>
                    <li><a href="https://github.com/ericcastro/" target="_blank" rel="noreferrer">Github</a></li>
                    <li><a href="https://www.last.fm/user/eric_castro" target="_blank" rel="noreferrer">Last.fm</a></li>
                    <li><a rel="me" href="https://mastodon.social/@ericcastro" target="_blank">Mastodon</a></li>
                    <li><a href="javascript:void(0)" id="emailLink">E-mail</a></li>
                    <li><a href="javascript:void(0)" id="guestbookLink">Guestbook</a></li>
                  </ul>

                </aside>

                <div class="sidebar-construction">
                  <img
                    class="construction-gif"
                    alt="under construction"
                    src="/images/construction.gif"
                    width="202"
                    height="27"
                    style="display:block;max-width:100%;height:auto;image-rendering:pixelated;"
                  />
                </div>

                <div class="sidebar-badges">
                  <img
                    src="/images/banner-best-viewed-with-any-browser-1996.gif"
                    alt="Best viewed with any browser"
                  />
                  <img
                    src="/images/banner-campaign-against-frames-1996.gif"
                    alt="Campaign against frames"
                  />
                  <img
                    src="/images/banner-made-with-notepad.gif"
                    alt="Made with Notepad"
                  />
                </div>

                <div class="sidebar-powered">
                  powered by <a href="/projects/ericos-95/">EricOS 95</a>
                </div>
              </div>

              <main class="content90s" id="top">
                <template id="browserHomeTemplate">
                  <div
                    id="postsFeed"
                    data-next-page="2"
                    data-total-pages={totalPostPages}
                  >
                    {initialPosts.map((entry) => <PostCard entry={entry} />)}
                  </div>
                  <div class="infinite-status" id="postFeedStatus" aria-live="polite">
                    {totalPostPages > 1 ? "Scroll down for older posts." : "All posts loaded."}
                  </div>
                  <div class="post-sentinel" id="postFeedSentinel" aria-hidden="true"></div>

                  <div class="guestbook">
                    <strong>Sign My Guestbook!</strong>
                    <p>Tell me your modem speed, your favorite operating system, and whether animated GIFs should make a comeback.</p>
                    <div class="counter90s" aria-label="visitor counter">
                      <span>0</span><span>0</span><span>1</span><span>3</span><span>3</span><span>7</span>
                    </div>
                  </div>
                </template>
                <template id="browserNotFoundTemplate">
                  <article class="post90s project-post">
                    <h2>404 Not Found</h2>
                    <p><strong>The requested page did not match any page inside EricOS 95.</strong></p>
                  </article>
                </template>
                <div id="browserContent">
                  <div
                    id="postsFeed"
                    data-next-page="2"
                    data-total-pages={totalPostPages}
                  >
                    {initialPosts.map((entry) => <PostCard entry={entry} />)}
                  </div>
                  <div class="infinite-status" id="postFeedStatus" aria-live="polite">
                    {totalPostPages > 1 ? "Scroll down for older posts." : "All posts loaded."}
                  </div>
                  <div class="post-sentinel" id="postFeedSentinel" aria-hidden="true"></div>

                  <div class="guestbook">
                    <strong>Sign My Guestbook!</strong>
                    <p>Tell me your modem speed, your favorite operating system, and whether animated GIFs should make a comeback.</p>
                    <div class="counter90s" aria-label="visitor counter">
                      <span>0</span><span>0</span><span>1</span><span>3</span><span>3</span><span>7</span>
                    </div>
                  </div>
                </div>
              </main>
            </div>
            <div class="footer90s">
              Copyright © 2026 Eric Castro. All rights reserved.
            </div>
          </div>
          </div>
        </div>
        <div class="status-bar">
          <div class="status-bar-field">Done</div>
          <div class="status-bar-field">Internet zone</div>
        </div>
      </div>
      <div class="resize-handle n" data-resize="n"></div>
      <div class="resize-handle e" data-resize="e"></div>
      <div class="resize-handle s" data-resize="s"></div>
      <div class="resize-handle w" data-resize="w"></div>
      <div class="resize-handle nw" data-resize="nw"></div>
      <div class="resize-handle ne" data-resize="ne"></div>
      <div class="resize-handle sw" data-resize="sw"></div>
      <div class="resize-handle se" data-resize="se"></div>
    </section>

    <section
      class="window"
      id="notes"
      data-window
      data-title="README - Notepad"
      style="left: 28px; top: 218px; width: 396px; height: 414px; z-index: 42;"
    >
      <div class="title-bar" data-drag-handle>
        <div class="title-left">
          <div class="title-icon note"></div>
          <div class="title-text title-bar-text">README - Notepad</div>
        </div>
        <div class="title-bar-controls">
          <button class="win-btn minimize" data-action="minimize" aria-label="Minimize"></button>
          <button class="win-btn maximize" data-action="maximize" aria-label="Maximize"></button>
          <button class="win-btn close" data-action="close" aria-label="Close"></button>
        </div>
      </div>
      <div class="menu-bar"><span>File</span><span>Edit</span><span>Search</span><span>Help</span></div>
      <div class="window-content notes-window-content">
        <div class="win-scroll-shell win-scroll-shell-about">
          <div class="about-body sunken win-scroll">
            <div
              class="editable-note editable-note-full"
              contenteditable="true"
              spellcheck="false"
              aria-label="Editable About Me text"
            >{aboutNoteText}</div>
          </div>
        </div>
      </div>
      <div class="resize-handle n" data-resize="n"></div>
      <div class="resize-handle e" data-resize="e"></div>
      <div class="resize-handle s" data-resize="s"></div>
      <div class="resize-handle w" data-resize="w"></div>
      <div class="resize-handle nw" data-resize="nw"></div>
      <div class="resize-handle ne" data-resize="ne"></div>
      <div class="resize-handle sw" data-resize="sw"></div>
      <div class="resize-handle se" data-resize="se"></div>
    </section>

    <section
      class="window hidden"
      id="projects"
      data-window
      data-title="Projects - Paint"
      style="left: 440px; top: 96px; width: 540px; height: 474px; z-index: 20;"
    >
      <div class="title-bar" data-drag-handle>
        <div class="title-left">
          <div class="title-icon paint"></div>
          <div class="title-text title-bar-text">Projects - Paint</div>
        </div>
        <div class="title-bar-controls">
          <button class="win-btn minimize" data-action="minimize" aria-label="Minimize"></button>
          <button class="win-btn maximize" data-action="maximize" aria-label="Maximize"></button>
          <button class="win-btn close" data-action="close" aria-label="Close"></button>
        </div>
      </div>
      <div class="menu-bar"><span>File</span><span>Edit</span><span>View</span><span>Image</span><span>Help</span></div>
      <div class="window-content">
        <div class="projects-layout">
          <div class="toolbox sunken">
            <div class="tool"></div><div class="tool"></div><div class="tool"></div>
            <div class="tool"></div><div class="tool"></div><div class="tool"></div>
          </div>
          <div class="paint-side">
            <div class="canvas-wrap sunken">
              <div class="canvas" id="projects-board">
                {
                  projectEntries.map((project) => (
                    <div
                      class:list={["pixel-card", project.data.color !== "yellow" && project.data.color]}
                      style={`left: ${project.data.x}px; top: ${project.data.y}px;${project.data.width ? ` width: ${project.data.width}px;` : ""}`}
                    >
                      <a href={`/projects/${project.slug}/`} class="pixel-card-link">
                        <strong>{project.data.title}</strong>
                        {project.data.summary}
                        <span class="pixel-card-period">{project.data.period}</span>
                      </a>
                    </div>
                  ))
                }
              </div>
            </div>
            <div class="palette sunken">
              <div class="swatch" style="background:black"></div><div class="swatch" style="background:gray"></div><div class="swatch" style="background:maroon"></div><div class="swatch" style="background:red"></div><div class="swatch" style="background:orange"></div><div class="swatch" style="background:yellow"></div><div class="swatch" style="background:lime"></div><div class="swatch" style="background:cyan"></div><div class="swatch" style="background:blue"></div><div class="swatch" style="background:fuchsia"></div><div class="swatch" style="background:white"></div>
            </div>
          </div>
        </div>
        <div class="status-bar"><div class="status-bar-field">For Help, click Help Topics on the Help Menu.</div></div>
      </div>
      <div class="resize-handle n" data-resize="n"></div>
      <div class="resize-handle e" data-resize="e"></div>
      <div class="resize-handle s" data-resize="s"></div>
      <div class="resize-handle w" data-resize="w"></div>
      <div class="resize-handle nw" data-resize="nw"></div>
      <div class="resize-handle ne" data-resize="ne"></div>
      <div class="resize-handle sw" data-resize="sw"></div>
      <div class="resize-handle se" data-resize="se"></div>
    </section>

    <section
      class="window hidden"
      id="retruco"
      data-window
      data-title="RETRUCO.exe"
      style="left: 300px; top: 88px; width: 656px; height: 627px; z-index: 24;"
    >
      <div class="title-bar" data-drag-handle>
        <div class="title-left">
          <div class="title-icon retruco"></div>
          <div class="title-text title-bar-text">RETRUCO.exe</div>
        </div>
        <div class="title-bar-controls">
          <button class="win-btn minimize" data-action="minimize" aria-label="Minimize"></button>
          <button class="win-btn maximize" data-action="maximize" aria-label="Maximize"></button>
          <button class="win-btn close" data-action="close" aria-label="Close"></button>
        </div>
      </div>
      <div class="menu-bar retruco-menu-bar" id="retrucoMenuBar">
        <div class="retruco-menu-root">
          <button
            class="retruco-menu-toggle"
            type="button"
            data-retruco-menu-toggle="juego"
            aria-expanded="false"
          >
            Juego
          </button>
          <div class="retruco-menu-panel window is-hidden" data-retruco-menu="juego">
            <button type="button" data-retruco-action="newMatch">Nuevo</button>
            <button type="button" data-retruco-action="choosePartner">Elegir Pareja</button>
            <button type="button" data-retruco-action="showSplash">Pantalla Inicial</button>
            <button type="button" data-retruco-action="showTable">Mesa</button>
          </div>
        </div>
        <div class="retruco-menu-root">
          <button
            class="retruco-menu-toggle"
            type="button"
            data-retruco-menu-toggle="ayuda"
            aria-expanded="false"
          >
            Ayuda
          </button>
          <div class="retruco-menu-panel window is-hidden" data-retruco-menu="ayuda">
            <button type="button" data-retruco-action="showInspector">Inspector</button>
            <button type="button" data-retruco-action="showAbout">Acerca De</button>
            <button type="button" data-retruco-action="copyState">Copiar Estado</button>
          </div>
        </div>
      </div>
      <div class="window-content retruco-window-content">
        <div class="retruco-widget-shell sunken">
          <div id="retrucoWidgetHost" class="retruco-widget-mount" aria-label="RETRUCO widget"></div>
        </div>
      </div>
      <div class="resize-handle n" data-resize="n"></div>
      <div class="resize-handle e" data-resize="e"></div>
      <div class="resize-handle s" data-resize="s"></div>
      <div class="resize-handle w" data-resize="w"></div>
      <div class="resize-handle nw" data-resize="nw"></div>
      <div class="resize-handle ne" data-resize="ne"></div>
      <div class="resize-handle sw" data-resize="sw"></div>
      <div class="resize-handle se" data-resize="se"></div>
    </section>

    <section
      class="window"
      id="cmd"
      data-window
      data-title="Command Prompt"
      style="left: 110px; top: 10px; width: 565px; height: 360px; z-index: 15;"
    >
      <div class="title-bar" data-drag-handle>
        <div class="title-left">
          <div class="title-icon cmd"></div>
          <div class="title-text title-bar-text">Command Prompt</div>
        </div>
        <div class="title-bar-controls">
          <button class="win-btn minimize" data-action="minimize" aria-label="Minimize"></button>
          <button class="win-btn maximize" data-action="maximize" aria-label="Maximize"></button>
          <button class="win-btn close" data-action="close" aria-label="Close"></button>
        </div>
      </div>
      <div class="window-content cmd-window-content">
        <div class="win-scroll-shell win-scroll-shell-fill">
          <div class="cmd-shell sunken win-scroll" id="cmdShell">Microsoff(R) EricOS 95
(C)Copyright Microsoff Corp 1981-1995.

<span class="prompt">C:\&gt;</span> net user webmaster
<div class="cmd-profile">
  <div class="cmd-kv"><span class="cmd-key">NAME</span><span class="cmd-value">{cmdEntry.data.name}</span></div>
  <div class="cmd-kv"><span class="cmd-key">LOCATION</span><span class="cmd-value">{cmdEntry.data.location}</span></div>
  <div class="cmd-kv"><span class="cmd-key">HOMETOWN</span><span class="cmd-value">{cmdEntry.data.hometown}</span></div>
  <div class="cmd-kv"><span class="cmd-key">OCCUPATION</span><span class="cmd-value">{cmdEntry.data.occupation}</span></div>
  <div class="cmd-kv"><span class="cmd-key">WEBSITE</span><span class="cmd-value">{cmdEntry.data.website}</span></div>
  <div class="cmd-kv"><span class="cmd-key">BIO</span><span class="cmd-value">{cmdEntry.data.bio}</span></div>
  <div class="cmd-kv"><span class="cmd-key">STATUS</span><span class="cmd-value">{cmdEntry.data.status}</span></div>
</div>

<div class="cmd-output" id="cmdOutput"></div>
<div class="cmd-input-line"><span class="prompt">C:\&gt;</span> <span class="cmd-entry" id="cmdEntry" contenteditable="true" spellcheck="false" aria-label="Command input"></span><span class="cmd-cursor">_</span></div></div>
        </div>
      </div>
      <div class="resize-handle n" data-resize="n"></div>
      <div class="resize-handle e" data-resize="e"></div>
      <div class="resize-handle s" data-resize="s"></div>
      <div class="resize-handle w" data-resize="w"></div>
      <div class="resize-handle nw" data-resize="nw"></div>
      <div class="resize-handle ne" data-resize="ne"></div>
      <div class="resize-handle sw" data-resize="sw"></div>
      <div class="resize-handle se" data-resize="se"></div>
    </section>

    <section
      class="window cookie-window is-hidden"
      id="cookieWidget"
      role="dialog"
      aria-live="polite"
      aria-label="Cookie notice"
      style="width: 320px; min-height: 0; z-index: 48;"
    >
      <div class="title-bar">
        <div class="title-left">
          <div class="title-icon note"></div>
          <div class="title-text title-bar-text">Cookie Notice</div>
        </div>
      </div>
      <div class="window-content cookie-body">
        <div class="alert-row">
          <div class="alert-symbol info" aria-hidden="true"></div>
          <p>This website uses cookies for extremely serious settings management and general European compliance theater.</p>
        </div>
        <div class="dialog-actions">
          <button class="default" id="cookieAccept" type="button">Accept All Cookies</button>
          <button id="cookieDecline" type="button">Decline</button>
        </div>
      </div>
    </section>

    <section
      class="window cookie-window is-hidden"
      id="myComputerWidget"
      role="dialog"
      aria-live="polite"
      aria-label="My Computer"
      style="width: 360px; min-height: 0; z-index: 47;"
    >
      <div class="title-bar">
        <div class="title-left">
          <div class="title-icon computer"></div>
          <div class="title-text title-bar-text">EricOS 95</div>
        </div>
      </div>
      <div class="window-content cookie-body">
        <div class="alert-row">
          <div class="alert-symbol warning" aria-hidden="true"></div>
          <p>I find it a bit weird that you want to access my computer. You can request access, but I don't guarantee I will give it to you anytime soon.</p>
        </div>
        <div class="dialog-actions">
          <button class="default" id="computerRequest" type="button">Request access</button>
          <button id="computerCancel" type="button">Cancel</button>
        </div>
      </div>
    </section>

    <section
      class="window cookie-window is-hidden"
      id="requestResultWidget"
      role="dialog"
      aria-live="polite"
      aria-label="EricOS 95"
      style="width: 250px; min-height: 0; z-index: 49;"
    >
      <div class="title-bar">
        <div class="title-left">
          <div class="title-text title-bar-text">EricOS 95</div>
        </div>
      </div>
      <div class="window-content cookie-body">
        <div class="alert-row">
          <div class="alert-symbol info" aria-hidden="true"></div>
          <p>Task failed successfully.</p>
        </div>
        <div class="dialog-actions">
          <button class="default" id="requestResultOk" type="button">OK</button>
        </div>
      </div>
