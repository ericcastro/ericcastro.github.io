---
import { render } from "astro:content";

interface Props {
  project: any;
}

const { project } = Astro.props;
const rendered = await render(project);
const Content = rendered.Content;
---

<article class="post90s project-post">
  <h2>{project.data.title}</h2>
  <div class="post-meta">{project.data.period}</div>
  <p><strong>{project.data.intro}</strong></p>

  {
    project.data.links.length ? (
      <div class="linkbox90s project-links-box">
        <h3>Links</h3>
        <ul>
          {project.data.links.map((link) => (
            <li><a href={link.url} target="_blank" rel="noreferrer">{link.label}</a></li>
          ))}
        </ul>
      </div>
    ) : null
  }

  <div class="markdown-body">
    <Content />
  </div>
</article>
