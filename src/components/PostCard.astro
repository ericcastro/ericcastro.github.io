---
import { render } from "astro:content";

interface Props {
  entry: any;
}

const { entry } = Astro.props;
const rendered = await render(entry);
const Content = rendered.Content;
---

<article class="post90s">
  <h2>{entry.data.title}</h2>
  <div class="post-meta">
    Posted on {entry.data.date}
    {entry.data.author ? ` by ${entry.data.author}` : ""}
    {entry.data.category ? (
      <>
        {" "}
        in the category <a href="#">{entry.data.category}</a>
      </>
    ) : null}
  </div>
  <Content />
  {
    entry.data.featured ? (
      <div class="button-row">
        <button class="ie-link-btn" type="button" data-open-window="notes">Open About</button>
        <button class="ie-link-btn" type="button" data-open-window="projects">Open Paint Portfolio</button>
        <button class="ie-link-btn" type="button" data-open-window="cmd">Open DOS Stats</button>
      </div>
    ) : null
  }
</article>
